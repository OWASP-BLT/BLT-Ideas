{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Generate Dashboard",
      "type": "shell",
      "command": "python",
      "args": ["scripts/generate_page.py"],
      "envFile": "${workspaceFolder}/.env",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": [],
      "detail": "Regenerates docs/index.html from all Idea-*.md files. Requires GITHUB_TOKEN in .env for live contributor data."
    },
    {
      "label": "Preview Dashboard",
      "type": "shell",
      "command": "start",
      "args": ["docs/index.html"],
      "windows": {
        "command": "start",
        "args": ["docs/index.html"]
      },
      "linux": {
        "command": "xdg-open",
        "args": ["docs/index.html"]
      },
      "osx": {
        "command": "open",
        "args": ["docs/index.html"]
      },
      "dependsOn": "Generate Dashboard",
      "group": "test",
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": [],
      "detail": "Generates the dashboard then opens docs/index.html in your default browser."
    },
    {
      "label": "Preview Only (no rebuild)",
      "type": "shell",
      "command": "start",
      "args": ["docs/index.html"],
      "windows": {
        "command": "start",
        "args": ["docs/index.html"]
      },
      "linux": {
        "command": "xdg-open",
        "args": ["docs/index.html"]
      },
      "osx": {
        "command": "open",
        "args": ["docs/index.html"]
      },
      "group": "test",
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": [],
      "detail": "Opens the last-built docs/index.html without regenerating."
    }
  ]
}
